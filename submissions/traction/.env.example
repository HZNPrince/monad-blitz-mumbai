# Web Scraping. Firecrawl provides intelligent document extraction.
FIRECRAWL_API_KEY=your_firecrawl_api_key

# Image generation. Local deterministic mode is used when live credentials are absent.
IMAGE_GENERATION_PROVIDER=local
CF_ACCOUNT_ID=
CLOUDFLARE_AI_API_TOKEN=
CLOUDFLARE_AI_MODEL=@cf/black-forest-labs/flux-1-schnell
TEXT_INTELLIGENCE_PROVIDER=local
CF_TEXT_MODEL=@cf/meta/llama-3.1-8b-instruct-fast

# Monad Testnet public configuration. These are network coordinates, not deployment claims.
NEXT_PUBLIC_MONAD_CHAIN_ID=10143
NEXT_PUBLIC_MONAD_RPC_URL=https://testnet-rpc.monad.xyz
NEXT_PUBLIC_MONAD_EXPLORER_URL=https://testnet.monadvision.com

# Future adapters. Leave blank until the corresponding feature is configured.
APP_BASE_URL=http://127.0.0.1:3000
# Optional in production; Next dev defaults to .data/traction-store.json.
TRACTION_STORE_PATH=
TRACKING_SIGNING_SECRET=
NEXT_PUBLIC_PRIVY_APP_ID=
NEXT_PUBLIC_PRIVY_CLIENT_ID=
PRIVY_APP_SECRET=
NEXT_PUBLIC_CAMPAIGN_FACTORY_ADDRESS=
NEXT_PUBLIC_MOCK_STABLECOIN_ADDRESS=
NEXT_PUBLIC_PERFORMANCE_ORACLE_ADDRESS=
NEXT_PUBLIC_CONVERSION_REGISTRY_ADDRESS=
NEXT_PUBLIC_AGENT_TREASURY_ADDRESS=
X_CLIENT_ID=
X_CLIENT_SECRET=
# Must exactly match the callback allowlisted in the X developer app. X requires
# 127.0.0.1 rather than localhost for local OAuth callbacks.
X_REDIRECT_URI=http://127.0.0.1:3000/api/connectors/x/callback
X_TOKEN_ENCRYPTION_KEY=
# Keep false for minimal text scopes. Set true and reconnect X to publish images.
X_MEDIA_UPLOAD_ENABLED=false
